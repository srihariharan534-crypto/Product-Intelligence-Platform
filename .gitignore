# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script, etc.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
#  Usually these files are written by a python script, etc.
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the values are
#   specific to the developer's sample development environment.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if the platform version is different, it may cause issues.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is of utility, but can be skipped in libraries
# poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is of utility, but can be skipped in libraries
pdm.lock
.pdm-plugins/

# PIP / Poetry virtualenvs
.venv/
venv/
ENV/
env/

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Project Data (Exclude Raw/Processed Datasets for size limit but keep the folder structure)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Exclude generated local databases
*.db
*.sqlite
